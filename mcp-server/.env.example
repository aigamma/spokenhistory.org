# mcp-server/.env.example — local-dev env-var template.
#
# Copy to .env.local (gitignored) or set as flyctl secrets for deploy:
#   flyctl secrets set PINECONE_API_KEY=... PINECONE_HOST=... VOYAGE_API_KEY=...
#
# Required for the MCP server to start at all (fail-fast on missing
# keys at process boot, before the first /mcp call).

# ── Pinecone ────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_INDEX=civil-rights

# ── Voyage AI ───────────────────────────────────────────────────────
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2

# ── Server ──────────────────────────────────────────────────────────
PORT=3001
MCP_RERANK_ENABLED=true
