# Civil Rights History Project — Environment Variables Template
#
# Copy this file to .env (gitignored) and fill in the actual values.
# Each section documents which subsystem requires the variable.

# ── Metadata Generation System (Python/Flask) ──────────────────────────
# Used by /Metadata Generation System/ when running the 7-step
# pipeline (blocking → labeling → TOC → chapterization → summarization →
# tuning → engagement scoring).

# OpenAI API key. Required.
# The existing pipeline uses gpt-4o-mini for labeling and main-summary
# scoring and gpt-4o for chapter summaries and chapter scoring.
OPENAI_API_KEY=sk-...

# Anthropic API key. Required to run the Claude Opus 4.7 external
# second-opinion scorer added in claude_scorer.py / tune_with_dual_scoring.
# Pipeline degrades gracefully if absent (Claude scoring is skipped) but
# the Smithsonian-grade publication gate requires it.
ANTHROPIC_API_KEY=sk-ant-...

# Optional override for the Claude scorer model.
# Defaults to claude-opus-4-7 (Opus is the right model for adversarial
# fact-checking of civil rights oral history summaries).
# CLAUDE_SCORER_MODEL=claude-opus-4-7

# Feature flag for the dual-scoring publication gate. When set to a
# truthy value (1, true, yes, on -- case-insensitive), the metadata
# pipeline runs the OpenAI tuning loop AND the Claude Opus 4.7
# second-opinion scorer, then applies the Smithsonian-grade 90/90
# threshold to BOTH scorers as a combined publication decision. Default
# (unset) is just the bare OpenAI loop at the 80/80 threshold. Setting
# this without ANTHROPIC_API_KEY also set will fail the Claude pass
# gracefully (logged warning, summary blocked from auto-publish) but the
# OpenAI loop still runs. See processor/dual_scoring_helper.py for the
# dispatch logic.
# USE_DUAL_SCORING=1

# Path to a Firebase service-account JSON downloaded from the Firebase
# Console (Project settings → Service accounts → Generate new private
# key). Required for the human-review queue producer
# (Metadata Generation System/processor/review_queue.py) to write
# pending summaries into the Firestore review_queue collection.
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/civil-rights-history-project-firebase-adminsdk.json

# ── React Frontend (Vite) ─────────────────────────────────────────────
# The Firebase Web SDK config is read from VITE_FIREBASE_* env vars
# (no hardcoded fallbacks since the secrets-scan-driven cleanup of
# 2026-05-21 -- see src/services/firebase.js). All six fields are
# REQUIRED -- the build will throw a clear "Missing required Firebase
# config env vars" error on module load if any of the six is missing.
# Source the values from Firebase Console → Project settings → Your
# apps → Web app → SDK setup and configuration. The apiKey is a
# public identifier per Firebase docs (firebase.google.com/docs/projects/api-keys),
# not a secret, so these can be committed if a deploy environment
# prefers that. For Netlify deploys: add them under Site settings →
# Environment variables, and ALSO add SECRETS_SCAN_OMIT_KEYS listing
# the six VITE_FIREBASE_* names so Netlify's secrets scanner does not
# flag the values inlined into the Vite bundle.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=civil-rights-history-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=civil-rights-history-project
VITE_FIREBASE_STORAGE_BUCKET=civil-rights-history-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# measurementId is optional -- Firebase Analytics only enables when this
# is set. Leave unset for the new project's deliberate no-Analytics
# privacy posture; firebase.js drops the field from firebaseConfig when
# the env var is missing.
# VITE_FIREBASE_MEASUREMENT_ID=

# ── Firebase Cloud Functions (Node.js) ────────────────────────────────
# Set these in the Firebase Functions environment via
# `firebase functions:secrets:set` rather than this file -- the secrets
# CLI is the correct surface for Cloud Functions secrets.

# OpenAI key for generateEmbedding / vectorSearch in functions/index.js.
# OPENAI_API_KEY=sk-...

# Canny feedback API key for the submitCannyFeedback function.
# CANNY_API_KEY=

# ── MCP Server ────────────────────────────────────────────────────────
# Used by /mcp-server/server.mjs.

# Firebase service-account credentials. The MCP server accepts EITHER
# of these (inline JSON takes precedence if both are set):
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/civil-rights-history-project-firebase-adminsdk.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# The JSON form is preferred for Fly.io / Railway / Render where secrets
# are env vars; the file path is preferred for local development.

# OpenAI key for query embedding via text-embedding-3-small (matches the
# embedding model the existing Cloud Function uses to populate the
# embeddings collection so query-side and document-side embeddings live
# in the same 1536-dimensional space).
# OPENAI_API_KEY=sk-...

# HTTP listen port. Default 3001 if unset.
# PORT=3001
