# Phase 3 derived artifacts — transcripts/corrected/ was previously
# gitignored as "regenerable from raw + overlay" but is now COMMITTED at
# Eric's explicit request so the adversarial multi-model ensemble (Kiro /
# Kimi / Codex / Gemini) can access the corrected text + per-entry
# review_metadata manifests directly via GitHub rather than re-running
# scripts/apply_corrections.py locally. Re-generate via
# `python scripts/apply_corrections.py`; commit deltas as needed.
# transcripts/corrected/

# rag/ env-var file — copied from rag/.env.example and populated with
# real credentials. Never commit (Pinecone + Voyage API keys).
rag/.env.local
rag/.env

# Intermediate subagent assignment files + per-batch capsule outputs.
# The aggregated capsules.json (committed) is what the React app
# consumes; the per-batch JSONs are dev-only intermediates.
public/rag/summaries/_batches/
public/rag/summaries/_entry_list.json
public/rag/summaries/capsules_batch_*.json

# Local-only scratch (Pinecone dumps, intermediate uploads, etc.)
tmp/

# Metadata Generation System per-entry subagent outputs: regenerable pipeline
# artifacts (chapterized interview summaries + the work queue). Same dev-only
# intermediate class as public/rag/summaries/_batches/ above; not committed.
Metadata Generation System/output_subagent/

# Microsoft Office lock files (the ~$ shadow file created while a doc is open).
~$*

# Scratch dir for the thumbnail-sourcing pass (never committed)
.photo_work/

# Re-chapterization (Pass v4) per-entry block intermediates. blocks_<N>.json
# and blocks_<N>.txt are deterministically regenerable from the entry's .srt
# via scripts/extract_blocks.py, so they are dev-only scratch. The hand-authored
# spec_<N>.json (chapter segmentation) and the staging output
# (transcripts/rechapter_staging/entry_<N>.chapters.json) ARE committed.
scripts/blocks_*.json
scripts/blocks_*.txt

# Essay harvest cache (reproducible Gutenberg downloads)
scripts/_essay_scratch/

# Local Netlify folder
.netlify

# Session-local research scratch for the technical paper
output/_paper_scratch/
