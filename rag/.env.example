# Civil Rights History Project — RAG layer environment variables
#
# Copy this file to .env.local for local development. Set the production
# values in the Netlify dashboard under Site settings → Environment
# variables (and/or the Supabase Edge Function secrets store, depending
# on where the chat function ultimately lives). Never commit a populated
# .env or .env.local — they are gitignored.

# ---------------------------------------------------------------------------
# Pinecone — vector retrieval
# ---------------------------------------------------------------------------
# The civil rights corpus lives in a SEPARATE Pinecone project from
# worldthought.com (both projects share a single organization under the
# Pinecone Builder $20/mo subscription, which supports multiple projects).
#
# Create the index in the Pinecone console with these settings:
#   - Dimension: 1024  (voyage-3)
#   - Metric: cosine
#   - Pod / Serverless: Serverless (Builder tier default)
#   - Cloud: aws-us-east-1 (or whichever region is closest to the
#     application's deployment region)
#   - Hybrid: enable sparse + dense (for BM25 + vector fusion)
#   - Optional: metadata indexes on entry_number, chunk_type
PINECONE_API_KEY=
PINECONE_INDEX=civil-rights
# Pinecone serverless index host — find this in the Pinecone console under
# the index's "Connect" tab. Format:
#   https://civil-rights-<project-hash>.svc.<region>.pinecone.io
PINECONE_HOST=

# ---------------------------------------------------------------------------
# Voyage AI — embeddings + reranking
# ---------------------------------------------------------------------------
# voyage-3 (1024-dim) is the default for document and query embedding.
# rerank-2 is the default for the second-stage reranker.
# Voyage API keys are issued at https://dash.voyageai.com/
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2

# ---------------------------------------------------------------------------
# Anthropic — chat / RAG-orchestration LLM
# ---------------------------------------------------------------------------
# Used by the chat function that consumes the retrieve.mjs output and
# generates the final answer with retrieved context. The dual-scorer +
# citation-auditor pipeline at Metadata Generation System/processor/ uses
# the same key.
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Build / deploy
# ---------------------------------------------------------------------------
SITE_HOST=civil-rights-staging.netlify.app
URL=https://civil-rights-staging.netlify.app
